# Standaard voor eerste referentieboard: ESP32-S3 (o.a. ESP32-S3 GEEK).
# ESP-IDF baseline: v5.4.2 (zie ESP_IDF_VERSION en BUILD.md).
# Build: idf.py set-target esp32s3 && idf.py build
# (Target staat in sdkconfig na set-target — niet hard forceren in defaults.)

CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_FREERTOS_HZ=1000

# Main draait app_core::run() → market_data::tick() met HTTPS (esp_http_client + mbedTLS).
# 3584 was te klein: stack overflow na STA_GOT_IP bij eerste Bitvavo REST/WS.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# T-103: HTTPS naar api.bitvavo.com / wss (TLS bundle)
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y

# SoftAP onboarding: mobiele browsers sturen vaak >512 B aan HTTP-headers (431 zonder deze verhoging)
CONFIG_HTTPD_MAX_REQ_HDR_LEN=2048

# S3-GEEK: fysiek 16 MB flash — align met partition table (geen 2 MB header-cap)
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# V2: dual OTA, 3 MiB per app-slot — zie partitions_v2_16mb_ota.csv + docs/flash/PARTITIONS_V2.md
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_v2_16mb_ota.csv"

# S3-GEEK ST7789 + LVGL: vastgelegd productprofiel — swap_bytes=0, RGB, 27 MHz (zie GEEK_DISPLAY_DIAG.md)
CONFIG_DISPLAY_DIAG_PROFILE_SWAP_OFF=y

# M-003a / M-013b: runtime service-toggles/poort/URI/topic — defaults uit Kconfig; NVS-overlay (schema v3, keys svc_*); M-013b: POST /api/services.json schrijft alleen mqtt/ntfy (geen webui_*).
# M-011a: NTFY staat default uit; zet CONFIG_NTFY_CLIENT_ENABLE=y + NTFY_TOPIC via menuconfig voor echte push.
# M-012a: MQTT-bridge default uit; zet CONFIG_MQTT_BRIDGE_ENABLE=y + MQTT_BROKER_URI voor echte publish.
# M-013a: read-only status-web — standaard aan (poort 8080); NVS `svc_wui_en` kan runtime uitzetten.
CONFIG_WEBUI_ENABLE=y
CONFIG_WEBUI_PORT=8080

# S30-1: canonieke prijsring ~32 min (1800s venster + 120s marge) voor 30m-%-metric.
CONFIG_DOMAIN_METRICS_30M_WINDOW_S=1800
CONFIG_DOMAIN_METRICS_CANONICAL_RING_EXTRA_S=120
# S2H-1: 2h %-move — aparte minuut-ring (~146 slots default), geen 7200×1 Hz canoniek.
CONFIG_DOMAIN_METRICS_2H_WINDOW_S=7200
CONFIG_DOMAIN_METRICS_2H_MINUTE_RING_EXTRA_SLOTS=24
# M-014a: OTA-upload via POST /api/ota (ruwe .bin); dual-slot zie partitions_v2_16mb_ota.csv.
# M-010a: domain_metrics + alert_engine — 1m-drempel 0,16% (zie ook sdkconfig).
CONFIG_ALERT_ENGINE_1M_THRESHOLD_BPS=16
CONFIG_ALERT_ENGINE_1M_COOLDOWN_S=120
CONFIG_ALERT_ENGINE_5M_THRESHOLD_BPS=32
CONFIG_ALERT_ENGINE_5M_COOLDOWN_S=300
# S30-2: 30m drempel + cooldown (Kconfig-only; outbound volgt S30-3).
CONFIG_ALERT_ENGINE_30M_THRESHOLD_BPS=64
CONFIG_ALERT_ENGINE_30M_COOLDOWN_S=1800
# S2H-2/S2H-3: 2h drempel + cooldown; outbound+observability via S2H-3 (NTFY/MQTT/alerts_2h).
CONFIG_ALERT_ENGINE_2H_THRESHOLD_BPS=128
CONFIG_ALERT_ENGINE_2H_COOLDOWN_S=7200
CONFIG_ALERT_ENGINE_CONF_1M5M_COOLDOWN_S=600
CONFIG_ALERT_ENGINE_CONF_SUPPRESS_LOOSE_S=8
CONFIG_ALERT_REGIME_VOL_WINDOW_SEC=90
CONFIG_ALERT_REGIME_VOL_MIN_PAIRS=30
CONFIG_ALERT_REGIME_VOL_PAIR_MIN_MS=800
CONFIG_ALERT_REGIME_VOL_PAIR_MAX_MS=2200
CONFIG_ALERT_REGIME_CALM_MAX_STEP_BPS=6
CONFIG_ALERT_REGIME_HOT_MIN_STEP_BPS=28
CONFIG_ALERT_REGIME_THR_SCALE_CALM_PERMILLE=900
CONFIG_ALERT_REGIME_THR_SCALE_NORMAL_PERMILLE=1000
CONFIG_ALERT_REGIME_THR_SCALE_HOT_PERMILLE=1180
CONFIG_ALERT_REGIME_THR_SCALE_MIN_PERMILLE=750
CONFIG_ALERT_REGIME_THR_SCALE_MAX_PERMILLE=1350
