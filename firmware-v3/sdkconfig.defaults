# Crypto-Alert V3 — defaults voor ESP32-S3-GEEK (16 MB flash)
# Build: idf.py set-target esp32s3 && idf.py build
# Eerste skeleton: standaard partition table; later eigen OTA-table indien nodig.

CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_FREERTOS_HZ=1000

CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# TLS / wss (Bitvavo) — voorbereiding voor market_ws
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y

CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# Development WiFi fallback (Crypto-Alert V3) — zet SSID/wachtwoord via idf.py menuconfig;
# laat defaults leeg; commit geen echte credentials in git.
CONFIG_CRYPTO_ALERT_WIFI_USE_DEV_FALLBACK=y
CONFIG_CRYPTO_ALERT_WIFI_SAVE_FALLBACK_TO_NVS=n
CONFIG_CRYPTO_ALERT_WIFI_SSID=""
CONFIG_CRYPTO_ALERT_WIFI_PASSWORD=""
CONFIG_CRYPTO_ALERT_WIFI_DHCP=y

# NTFY defaults (disabled by default; topic intentionally empty)
CONFIG_CRYPTO_ALERT_NTFY_ENABLE=n
CONFIG_CRYPTO_ALERT_NTFY_SERVER_URL="https://ntfy.sh"
CONFIG_CRYPTO_ALERT_NTFY_TOPIC=""
CONFIG_CRYPTO_ALERT_NTFY_MIN_QUALITY=2
CONFIG_CRYPTO_ALERT_NTFY_COOLDOWN_SEC=60
